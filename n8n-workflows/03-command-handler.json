    {
      "parameters": {
        "jsCode": "// Format memory list\nconst items = $('Get All Memory').all();\n\nif (!items || items.length === 0) {\n  return [{\n    json: {\n      message: '🧠 I don\\'t remember anything yet!\\n\\nUse /remember to tell me things I should remember. 😊',\n      chatId: $input.first().json.chatId\n    }\n  }];\n}\n\nlet message = '🧠 **Here\\'s what I remember about you:**\\n\\n';\nitems.forEach((item, index) => {\n  message += `${index + 1}. ${item.json.fact}\\n`;\n});\n\nmessage += '\\n💡 Use /remember to add more!';\n\nreturn [{\n  json: {\n    message: message,\n    chatId: $input.first().json.chatId\n  }\n}];"
      },
