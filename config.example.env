# ─── Ronku-Bot Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp config.example.env .env

# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_OWNER_USERNAME=      # Your Telegram username (without @)
TELEGRAM_OWNER_CHAT_ID=       # Your Telegram numeric chat ID

# ─── Owner Identity ─────────────────────────────────────────────────────────
OWNER_NAME=                   # Your full name (used in bot personality)

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_OWNER_EMAIL=              # n8n login email
N8N_BASIC_AUTH_PASSWORD=      # n8n login password

# ─── Ngrok (for exposing n8n webhook to Telegram) ───────────────────────────
NGROK_URL=                    # e.g. https://your-domain.ngrok-free.dev
NGROK_DOMAIN=                 # e.g. your-domain.ngrok-free.dev

# ─── AI Providers ───────────────────────────────────────────────────────────
GEMINI_API_KEY=               # Google Gemini
GROQ_API_KEY=                 # Groq (optional)
GITHUB_TOKEN=                 # GitHub Models (optional)

# ─── Mac-Agent ──────────────────────────────────────────────────────────────
MAC_AGENT_HOST=127.0.0.1
MAC_AGENT_PORT=4242
