# ─── Ronku-Bot Configuration ────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp config.example.env .env

# ─── Telegram ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_BOT_NAME=            # Your bot's username (without @)
TELEGRAM_OWNER_USERNAME=      # Your Telegram username (without @)
TELEGRAM_OWNER_CHAT_ID=       # Your numeric Telegram chat ID
# To find your chat ID:
#   1. Start your bot and send it any message
#   2. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. Look for "chat":{"id":123456789} — that number is your chat ID

# ─── Owner Identity ─────────────────────────────────────────────────────────
OWNER_NAME=                   # Your full name (used in bot personality)
OWNER_FIRST_NAME=             # First name (for n8n account)
OWNER_LAST_NAME=              # Last name (for n8n account)

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=      # n8n login password (auto-generated by installer)
N8N_OWNER_EMAIL=              # n8n login email
N8N_ENCRYPTION_KEY=           # Run: openssl rand -hex 32

# ─── Database ────────────────────────────────────────────────────────────────
DB_TYPE=sqlite
DB_SQLITE_PATH=/home/node/.n8n/database/ronkbot.db

# ─── Ngrok (for exposing n8n webhook to Telegram) ───────────────────────────
# See docs/NGROK_SETUP.md for setup instructions
NGROK_URL=                    # e.g. https://your-domain.ngrok-free.dev
NGROK_DOMAIN=                 # e.g. your-domain.ngrok-free.dev

# ─── AI Providers ───────────────────────────────────────────────────────────
GEMINI_API_KEY=               # Google Gemini (required)
GROQ_API_KEY=                 # Groq (optional)
GITHUB_TOKEN=                 # GitHub Models (optional)

# ─── Mac-Agent ──────────────────────────────────────────────────────────────
MAC_AGENT_HOST=127.0.0.1
MAC_AGENT_PORT=4242
